# Konfigurasi Database
DB_HOST=localhost
DB_USER=unilibra
DB_PASSWORD=unilibra
DB_NAME=unilibra
DB_PORT=5432

# Keamanan
JWT_SECRET=ganti-dengan-secret-panjang
ADMIN_EMAILS=admin@unilibra.local

# Backend dan frontend
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AI_ENGINE_URL=http://localhost:8000
AI_INTERNAL_TOKEN=ganti-token-internal-ai

# Google OAuth backend
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Upload cover local
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:8080/uploads

# Azure Blob Storage untuk production bila STORAGE_PROVIDER=azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=book-covers
AZURE_STORAGE_PUBLIC_BASE_URL=

# AI service
DATABASE_URL=postgresql://unilibra:unilibra@localhost:5432/unilibra
AI_SEED_OWNER_EMAIL=dataset@unilibra.local
GEMINI_API=
